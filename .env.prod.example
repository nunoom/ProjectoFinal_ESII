# Copiar para .env e preencher antes de: docker compose -f docker-compose.prod.yml up -d --build

# Segredo de assinatura dos JWT (gerar um aleatório longo)
EHA_JWT_SECRET=troca-por-um-segredo-aleatorio-muito-longo-e-secreto

# Password do PostgreSQL
DB_PASSWORD=eha2026

# URL(s) do frontend, separadas por vírgula (para o CORS)
EHA_CORS_ORIGINS=https://projecto-final-esii.vercel.app

# SMTP para enviar os emails de verificação/recuperação (ex.: Gmail com app password)
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=465
SPRING_MAIL_USERNAME=o-teu-email@gmail.com
SPRING_MAIL_PASSWORD=a-tua-app-password-sem-espacos
EHA_MAIL_FROM=o-teu-email@gmail.com
