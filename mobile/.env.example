# Backend API Configuration
# =========================

# Production Backend (Railway)
EXPO_PUBLIC_API_URL=https://projectofinalesii-production.up.railway.app/api

# Local Development Backend
# EXPO_PUBLIC_API_URL=http://localhost:8080/api

# Android Emulator Backend
# EXPO_PUBLIC_API_URL=http://10.0.2.2:8080/api

# iOS Simulator Backend
# EXPO_PUBLIC_API_URL=http://localhost:8080/api

# LAN/Network Backend (para dispositivos físicos na mesma rede)
# EXPO_PUBLIC_API_URL=http://192.168.1.x:8080/api
# Substitua 192.168.1.x pelo IP local do seu computador
